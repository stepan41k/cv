const education = [
    {
        institution:
            "Новгородский государственный университет им. Ярослава Мудрого",
        city: "Великий Новгород",
        faculty: "Институт электронных и информационных систем",
        specialty: "Информатика и вычислительная техника",
        period: "2022 — 2027",
    },
];
---

<Layout title="Golang Backend Developer">
    <header class="header">
        <h1>Распопов Степан</h1>
        <p>Golang Backend Developer</p>

        <div class="status-container">
            <div class="status-badge">
                <span class="status-dot"></span>
                <span class="status-text">Открыт к предложениям</span>
            </div>
        </div>

        <div class="contact-links">
            <span class="contact-item">+79808559409</span>
            <span class="contact-item">stepan.raspopov.ig@gmail.com</span>
            <a href="https://github.com/stepan41k" target="_blank">GitHub</a>
            <a href="https://t.me/stepanigorevichr" target="_blank">Telegram</a>
        </div>
    </header>

    <container>
        <section>
            <h2>Навыки</h2>
            <div>
                {skills.map((skill) => <span class="badge">{skill}</span>)}
            </div>
        </section>

        <section>
            <h2>Достижения</h2>
            {
                experience.map((job) => (
                    <div class="job-card">
                        <div class="job-header">
                            <span class="role">{job.name}</span>
                        </div>

                        <ul class="achievement-list">
                            {job.achievements.map((item) => (
                                <li
                                    class="achievement-item"
                                    set:html={item.replace(
                                        /\*\*(.*?)\*\*/g,
                                        "<b>$1</b>",
                                    )}
                                />
                            ))}
                        </ul>

                        <div class="tag-container">
                            {job.stack.map((tag) => (
                                <span
                                    class={`tag ${tag.primary ? "primary" : ""}`}
                                >
                                    {tag.name}
                                </span>
                            ))}
                        </div>
                    </div>
                ))
            }
        </section>

        <section>
            <h2 class="section-title">Образование</h2>
            {
                education.map((edu) => (
                    <div class="interactive-card education-grid">
                        <div class="card-period">{edu.period}</div>
                        <div class="card-content">
                            <h3>{edu.institution}</h3>
                            <p class="location">{edu.city}</p>
                            <p class="details">
                                {edu.faculty}, {edu.specialty}
                            </p>
                        </div>
                    </div>
                ))
            }
        </section>

        <section>
            <h2 class="section-title">О себе</h2>
            <div class="interactive-card about-box">
                <p>
                    Разрабатываю backend-сервисы на <b>Go</b>. Работаю с
                    построением
                    <div class="has-details">
                        асинхронных пайплайнов
                        <ul class="details-popup">
                            <li>Kafka</li>
                            <li>NATS</li>
                            <li>RabbitMQ</li>
                        </ul>
                    </div>
                    и идемпотентной обработкой. Настраиваю
                    <div class="has-details">
                        Observability
                        <ul class="details-popup">
                            <li>Graylog</li>
                            <li>Prometheus</li>
                            <li>VicrotiaMetrics</li>
                            <li>Grafana</li>
                            <li>OpenTelemetry</li>
                            <li>Jaeger</li>
                        </ul>
                    </div>
                    и логирование, выстраиваю CI/CD пайплайны. Покрываю написанный
                    код юнит, интеграционными, e2e, нагрузочными тестами. В свободное
                    время интересуюсь
                    <div class="has-details">
                        DevOps
                        <ul class="details-popup">
                            <li>Docker</li>
                            <li>Kubernetes</li>
                            <li>Helm</li>
                            <li>Terraform</li>
                            <li>Ansible</li>
                            <li>Zabbix</li>
                        </ul>
                    </div>
                    и сетевой инженерией, немного изучаю
                    <div class="has-details">
                        Frontend
                        <ul class="details-popup">
                            <li>TypeScript</li>
                            <li>React</li>
                            <li>Vue</li>
                        </ul>
                    </div>
                    , а также интересуюсь и практикуюсь в
                    <div class="has-details">
                        Linux
                        <ul class="details-popup">
                            <li>bash</li>
                            <li>systemd</li>
                            <li>htop</li>
                            <li>grep</li>
                            <li>wireshark</li>
                            <li>strace</li>
                        </ul>
                    </div>.
                </p>
            </div>
        </section>
    </container>
</Layout>
